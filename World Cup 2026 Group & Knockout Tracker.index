let koscores = JSON.parse(localStorage.getItem('wc26koscores_v3')||'{}');
function normalizeScore(val){ if(val === '' || val === null || val === undefined) return ''; const n = parseInt(val,10); return Number.isFinite(n) ? String(Math.max(0,n)) : ''; }
function saveScore(no, side, val){ if(!scores[no]) scores[no]={h:'',a:''}; scores[no][side]=normalizeScore(val); localStorage.setItem('wc26scores_v3',JSON.stringify(scores)); render(); }
function saveKoScore(no, side, val){ if(!koscores[no]) koscores[no]={h:'',a:''}; koscores[no][side]=normalizeScore(val); localStorage.setItem('wc26koscores_v3',JSON.stringify(koscores)); render(); }
function resetScores(){ scores={}; koscores={}; localStorage.removeItem('wc26scores_v3'); localStorage.removeItem('wc26koscores_v3'); render(); }
function hasScorePair(s){ return s && s.h !== '' && s.a !== '' && s.h !== undefined && s.a !== undefined && s.h !== null && s.a !== null; }
function recalc(group){ const rows=groups[group].map(t=>({group,team:t,p:0,w:0,d:0,l:0,gf:0,ga:0,gd:0,pts:0})); const map=Object.fromEntries(rows.map(r=>[r.team,r])); matches.filter(m=>m.group===group).forEach(m=>{let s=scores[m.no]||{}; if(!hasScorePair(s))return; let h=parseInt(s.h,10),a=parseInt(s.a,10),H=map[m.home],A=map[m.away]; H.p++;A.p++;H.gf+=h;H.ga+=a;A.gf+=a;A.ga+=h; if(h>a){H.w++;A.l++;H.pts+=3}else if(a>h){A.w++;H.l++;A.pts+=3}else{H.d++;A.d++;H.pts+=1;A.pts+=1} }); rows.forEach(r=>r.gd=r.gf-r.ga); rows.sort((a,b)=>b.pts-a.pts||b.gd-a.gd||b.gf-a.gf||a.team.localeCompare(b.team)); return rows; }
function allStandings(){let out={}; Object.keys(groups).forEach(g=>out[g]=recalc(g)); return out;}
function thirdRanking(){return Object.keys(groups).map(g=>recalc(g)[2]).sort((a,b)=>b.pts-a.pts||b.gd-a.gd||b.gf-a.gf||a.team.localeCompare(b.team));}
function qualifier(seed){ const st=allStandings(); if(seed.startsWith('W')) return winner(+seed.slice(1)); if(seed.startsWith('L')) return loser(+seed.slice(1)); if(seed[0]==='1') return st[seed[1]]?.[0]?.team || seed; if(seed[0]==='2') return st[seed[1]]?.[1]?.team || seed; if(seed.startsWith('3rd')){ let allowed=seed.replace('3rd ','').split('/'); let thirds=thirdRanking().slice(0,8).filter(x=>allowed.includes(x.group)); return thirds[0]?.team || seed; } return seed; }
function winner(no){ let m=knockout.find(x=>x.no===no); if(!m) return 'W'+no; let h=qualifier(m.home), a=qualifier(m.away), s=koscores[no]||{}; if(s.h===''||s.a===''||s.h==null||s.a==null||+s.h===+s.a) return 'W'+no; return +s.h>+s.a?h:a; }
function loser(no){ let m=knockout.find(x=>x.no===no); if(!m) return 'L'+no; let h=qualifier(m.home), a=qualifier(m.away), s=koscores[no]||{}; if(s.h===''||s.a===''||s.h==null||s.a==null||+s.h===+s.a) return 'L'+no; return +s.h<+s.a?h:a; }
function teamName(t){return (flags[t]?flags[t]+' ':'')+t;}
function formatGD(n){ n = Number(n)||0; return n>0 ? '+'+n : String(n); }
function groupCard(g){ const standings=recalc(g), ms=matches.filter(m=>m.group===g); return `<article class='card'><h2>Group ${g} <span class='pill'>W=3 · D=1 · L=0</span></h2><table><thead><tr><th></th><th class='team'>Team</th><th>P</th><th>W</th><th>D</th><th>L</th><th>GD</th><th>Points</th></tr></thead><tbody>${standings.map((r,i)=>`<tr><td class='rank'>${i+1}</td><td class='team'><span class='flag'>${flags[r.team]}</span>${r.team}</td><td>${r.p}</td><td>${r.w}</td><td>${r.d}</td><td>${r.l}</td><td class='gd'>${formatGD(r.gd)}</td><td class='points'><b>${r.pts}</b></td></tr>`).join('')}</tbody></table><div class='matches'>${ms.map(m=>{let s=scores[m.no]||{};return `<div class='match'><div class='kickoff'>Match ${m.no}<br><span>Kick-off CET: ${m.cet_date} · ${m.cet_time}</span></div><span class='home'>${flags[m.home]} ${m.home}</span><input class='score' type='number' min='0' step='1' value='${s.h??""}' oninput='saveScore(${m.no},"h",this.value)'><b>–</b><input class='score' type='number' min='0' step='1' value='${s.a??""}' oninput='saveScore(${m.no},"a",this.value)'><span class='away'>${m.away} ${flags[m.away]}</span><small>${m.venue}</small></div>`}).join('')}</div></article>`; }
function koCard(round){ const list=knockout.filter(m=>m.round===round); return `<article class='card'><h2>${round}</h2><div class='note'>Entrants update from group standings. For third-place slots, the dashboard picks the highest-ranked qualifying third-place team from the allowed groups shown in the official slot.</div>${list.map(m=>{let h=qualifier(m.home),a=qualifier(m.away),s=koscores[m.no]||{},w=winner(m.no);return `<div class='koMatch'><div class='koTitle'><span>Match ${m.no} · ${m.date} ${m.time} CET</span><span>${m.venue}</span></div><div class='koRow ${w===h?'winner':''}'><span>${teamName(h)}</span><input class='score' type='number' min='0' value='${s.h??""}' oninput='saveKoScore(${m.no},"h",this.value)'></div><div class='koRow ${w===a?'winner':''}'><span>${teamName(a)}</span><input class='score' type='number' min='0' value='${s.a??""}' oninput='saveKoScore(${m.no},"a",this.value)'></div></div>`}).join('')}</article>`; }
function render(){ const gf=document.getElementById('groupFilter').value; const list=Object.keys(groups).filter(g=>gf==='ALL'||g===gf); document.getElementById('groupsGrid').innerHTML=list.map(groupCard).join(''); document.getElementById('scheduleRows').innerHTML=matches.filter(m=>gf==='ALL'||m.group===gf).map(m=>{let s=scores[m.no]||{};let sc=(s.h!==undefined&&s.h!==''&&s.a!==undefined&&s.a!=='')?`${s.h}–${s.a}`:'';return `<tr><td>${m.no}</td><td class='scheduleTime'>${m.cet_date}</td><td class='scheduleTime'>${m.cet_time} CET</td><td>${m.group}</td><td>${sc}</td><td>${flags[m.home]} ${m.home} vs ${flags[m.away]} ${m.away}</td><td>${m.venue}</td></tr>`}).join(''); document.getElementById('thirdRows').innerHTML=thirdRanking().map((r,i)=>`<tr><td>${i+1}</td><td>${i<8?'✅':'—'}</td><td>${r.group}</td><td class='team'>${flags[r.team]} ${r.team}</td><td class='points'><b>${r.pts}</b></td><td class='gd'>${formatGD(r.gd)}</td></tr>`).join(''); document.getElementById('bracketGrid').innerHTML=['Round of 32','Round of 16','Quarter-final','Semi-final','Third place','Final'].map(koCard).join(''); }
function showView(v,btn){ ['groups','schedule','knockout'].forEach(x=>document.getElementById(x+'View').classList.toggle('hidden',v!==x)); document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active')); btn.classList.add('active'); }
render();
</script></body></html>
