<!DOCTYPE html>
<!-- saved from url=(0080)file:///Users/renebryruplauridsen/Downloads/world_cup_2026_group_tracker_v3.html -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"><meta http-equiv="Cache-Control" content="no-store"><meta http-equiv="Pragma" content="no-cache"><meta name="viewport" content="width=device-width,initial-scale=1"><title>World Cup 2026 Group &amp; Knockout Tracker</title><style>
:root{--bg:#07111f;--card:#101b2f;--ink:#eef6ff;--muted:#9fb3c8;--line:rgba(255,255,255,.12);--gold:#ffd166;--green:#48e5a2;--blue:#69a7ff;--red:#ff7b7b}*{box-sizing:border-box}body{margin:0;font-family:Inter,Segoe UI,Arial,sans-serif;background:radial-gradient(circle at top left,#173b75,#07111f 45%,#05080f);color:var(--ink)}header{padding:34px 26px 20px;position:sticky;top:0;background:linear-gradient(180deg,rgba(7,17,31,.97),rgba(7,17,31,.80));backdrop-filter:blur(8px);z-index:5;border-bottom:1px solid var(--line)}h1{margin:0;font-size:clamp(28px,4vw,54px);letter-spacing:-.04em}.subtitle{color:var(--muted);margin-top:8px;font-size:15px}.toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}button,input,select{border:1px solid var(--line);background:#0f1b30;color:var(--ink);border-radius:12px;padding:10px 12px}button{cursor:pointer;background:linear-gradient(135deg,#2457ff,#06b6d4);font-weight:700}main{padding:22px;max-width:1600px;margin:0 auto}.stats{display:grid;grid-template-columns:repeat(5,minmax(150px,1fr));gap:14px;margin-bottom:20px}.kpi{background:linear-gradient(135deg,rgba(255,255,255,.12),rgba(255,255,255,.04));border:1px solid var(--line);border-radius:22px;padding:18px}.kpi b{font-size:32px;display:block}.tabs{display:flex;gap:10px;margin:20px 0;flex-wrap:wrap}.tab{background:#0c1627;border:1px solid var(--line)}.tab.active{outline:2px solid var(--gold)}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(330px,1fr));gap:16px}.card{background:rgba(16,27,47,.82);border:1px solid var(--line);border-radius:24px;box-shadow:0 16px 40px rgba(0,0,0,.25);overflow:hidden}.card h2{margin:0;padding:16px 18px;background:linear-gradient(90deg,rgba(255,209,102,.22),rgba(105,167,255,.10));font-size:20px}table{width:100%;border-collapse:collapse}th,td{padding:9px 10px;border-bottom:1px solid rgba(255,255,255,.08);text-align:center;font-size:13px}th{color:#cfe2ff;font-weight:700}td.team,th.team{text-align:left}.rank{width:26px;color:var(--gold);font-weight:800}.flag{font-size:22px;margin-right:8px;vertical-align:middle}.matches{display:grid;gap:10px;padding:14px}.match{display:grid;grid-template-columns:1fr 52px 28px 52px 1fr;gap:8px;align-items:center;background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:9px}.match .home{text-align:right}.match .away{text-align:left}.match small{grid-column:1/-1;color:var(--muted);text-align:center}.kickoff{grid-column:1/-1;text-align:center;font-weight:800;color:#ffd166;background:rgba(255,209,102,.10);border:1px solid rgba(255,209,102,.22);border-radius:12px;padding:6px 8px;margin-bottom:2px}.scheduleTime{font-weight:800;color:#ffd166;white-space:nowrap}.points{font-weight:800;color:#16a34a}.gd{font-variant-numeric:tabular-nums}.scoreNote{color:var(--green);font-size:12px;margin-left:8px}.score{width:52px;text-align:center;font-weight:800;font-size:16px}.pill{display:inline-block;padding:4px 8px;border-radius:999px;background:rgba(72,229,162,.14);color:#bfffe5;font-size:11px}.scheduleTable td:nth-child(6){text-align:left}.hidden{display:none}.bracket{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:14px}.koMatch{background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.09);border-radius:18px;padding:12px;margin:10px}.koTitle{display:flex;justify-content:space-between;color:var(--muted);font-size:12px;margin-bottom:8px}.koRow{display:grid;grid-template-columns:1fr 52px;gap:8px;align-items:center;margin:6px 0}.winner{color:var(--green);font-weight:800}.note{color:var(--muted);font-size:12px;padding:12px 16px}footer{padding:24px;color:var(--muted);font-size:12px}@media(max-width:800px){.stats{grid-template-columns:1fr 1fr}.match{grid-template-columns:1fr 42px 20px 42px 1fr}.bracket{grid-template-columns:1fr}}
</style></head><body>
<header><h1>🏆 FIFA World Cup 2026 Tracker</h1><div class="subtitle"><b>Updated version:</b> CET kick-off date + exact time are now shown on every match card and in the All matches table. Standings use win = 3, draw = 1, loss = 0.</div><div class="subtitle">Editable browser dashboard with exact CET kick-off date + time, live 3/1/0 group tables, best third-place ranking, and knockout overview.</div><div class="toolbar"><button onclick="resetScores()">Reset scores</button><button onclick="window.print()">Print / save PDF</button><select id="groupFilter" onchange="render()"><option value="ALL">All groups</option><option>A</option><option>B</option><option>C</option><option>D</option><option>E</option><option>F</option><option>G</option><option>H</option><option>I</option><option>J</option><option>K</option><option>L</option></select></div></header>
